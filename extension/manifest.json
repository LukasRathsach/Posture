{
  "manifest_version": 3,
  "name": "Posture",
  "description": "Trade with discipline. Overlay for Axiom that syncs with your Posture account.",
  "version": "0.2.0",
  "permissions": [
    "storage",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "https://*.supabase.co/*",
    "https://api.dexscreener.com/*",
    "https://posture-chi.vercel.app/*",
    "https://*.ingest.de.sentry.io/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://axiom.trade/*",
        "https://*.axiom.trade/*"
      ],
      "js": [
        "socket-hook.js"
      ],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://axiom.trade/*",
        "https://*.axiom.trade/*"
      ],
      "css": [
        "overlay.css"
      ],
      "js": [
        "config.js",
        "trade-contract.js",
        "sentry.bundle.min.js",
        "overlay.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://posture-chi.vercel.app/*",
        "http://localhost/*",
        "http://localhost:*/*",
        "http://127.0.0.1/*",
        "http://127.0.0.1:*/*"
      ],
      "js": [
        "config.js",
        "trade-contract.js",
        "dashboard-bridge.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Posture",
    "default_popup": "popup.html"
  }
}
