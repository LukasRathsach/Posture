{
  "manifest_version": 3,
  "name": "Posture",
  "description": "Trade with discipline. Overlay for Axiom that syncs with your Posture account.",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://*.supabase.co/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://axiom.trade/*",
        "https://*.axiom.trade/*"
      ],
      "css": [
        "overlay.css"
      ],
      "js": [
        "config.js",
        "overlay.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Posture",
    "default_popup": "popup.html"
  }
}
